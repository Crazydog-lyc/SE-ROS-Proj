1. 构建镜像

```bash
docker build -t nav2-merged .
```

2. 启动主容器

```bash
docker run -it --rm \
  --name nav2-merged \
  --network host \
  nav2-merged \
  bash
```

容器内先执行：

```bash
source /opt/ros/humble/setup.bash
source /ws/install/setup.bash
```

3. 启动完整栈

```bash
ros2 launch course_bringup mission_demo.launch.py enable_semantic:=True enable_safety:=True
```

4. 新开第二个终端进入同一个容器，发送任务

```bash
docker exec -it nav2-merged bash
source /opt/ros/humble/setup.bash
source /ws/install/setup.bash
ros2 action send_goal /mission/run course_interfaces/action/RunMission \
'{mission_file: "/ws/src/course_bringup/config/sample_mission.json", max_retry_per_waypoint: 1, allow_skip_waypoint: false}'
```

5. 新开第三个终端观察任务状态

```bash
docker exec -it nav2-merged bash
source /opt/ros/humble/setup.bash
source /ws/install/setup.bash
ros2 topic echo /mission/state
```

6. 生成并运行批量场景

```bash
docker exec -it nav2-merged bash
source /opt/ros/humble/setup.bash
source /ws/install/setup.bash
